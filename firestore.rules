rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields: id, name, email, role, classId, assignedSubjects, telegram, gmail, avatarUrl
    //
    // Collection: attendance
    // Document ID: recordId (studentId-date)
    // Fields: id, studentId, classId, date, status, reason
    //
    // Collection: scores
    // Document ID: scoreId (studentId-subjectName)
    // Fields: studentId, subjectName, grade (map), lastUpdated
    //
    // Collection: evaluations
    // Document ID: evaluationId
    // Fields: id, student_id, teacher_id, subject, evaluation_title, evaluation_comment, score, date
    //
    // Collection: schedules
    // Document ID: scheduleId
    // Fields: id, student_id, subject_name, date, start_time, end_time, description, is_completed, created_at
    //
    // Collection: notes
    // Document ID: noteId
    // Fields: id, student_id, title, text_content, image_url, subject_name, schedule_datetime, created_at, updated_at
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         (request.auth.token.email == "saochhay.kim.761@happychandara.org" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher' || isAdmin());
    }

    function isStudent() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Student');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // For the demo, allow any user to read/write profiles
      // In a production app, this should be restricted to authenticated users
      allow read, write: if true;
    }

    match /attendance/{recordId} {
      allow read, write: if true;
    }

    match /scores/{scoreId} {
      allow read, write: if true;
    }

    match /evaluations/{evaluationId} {
      allow read, write: if true;
    }

    match /schedules/{scheduleId} {
      allow read, write: if true;
    }

    match /notes/{noteId} {
      allow read, write: if true;
    }
  }
}
